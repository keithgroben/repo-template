# ─── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ─── Vite (exposed to SPA via import.meta.env) ──────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# Set this to your app's path prefix (e.g., /porkchop/) if served under a subpath.
# Leave blank or '/' if served at the root domain.
# VITE_BASE_PATH=/appname/

# ─── Supabase (server only) ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
# Service role key: used ONLY in Hono server for admin operations.
# NEVER expose this in the SPA or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Auth (pick one) ─────────────────────────────────────
# For Supabase JWT auth: no extra config needed (uses SUPABASE_* above)
# For PIN auth (internal tools):
# APP_PIN=your-secure-pin-here

# ─── External APIs (app-specific) ────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# RESEND_API_KEY=re_...
# RESEND_FROM=noreply@example.com
