# ─── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ─── Supabase ────────────────────────────────────────────
# Anon key: used in SPA (via VITE_SUPABASE_ANON_KEY) and in Hono for user-scoped clients
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Service role key: used ONLY in Hono server for admin operations
# NEVER expose this in the SPA or commit it to git
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Auth (pick one) ─────────────────────────────────────
# For Supabase JWT auth: no extra config needed (uses SUPABASE_* above)
# For PIN auth (internal tools):
# APP_PIN=your-secure-pin-here

# ─── Caddy ───────────────────────────────────────────────
CADDY_PORT=8080
CADDY_TLS_PORT=8443

# ─── PostgreSQL (if self-hosted, not using Supabase cloud) ─
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=app
# PG_USER=postgres
# PG_PASSWORD=change-me

# ─── External APIs (app-specific) ────────────────────────
# RESEND_API_KEY=re_...
# RESEND_FROM=noreply@example.com
# ANTHROPIC_API_KEY=sk-ant-...
# FRAMEIO_CLIENT_SECRET=...
